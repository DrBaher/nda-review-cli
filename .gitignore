config/integrations.json

# env/OS
.DS_Store
*.log

__pycache__/
*.pyc

# Build artifacts
dist/
build/
*.egg-info/

# Web demo runtime artifacts (sandboxed per-session dirs; not for commit)
/tmp/nda-demo-sandbox/
