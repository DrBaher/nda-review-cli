config/llm.json
config/quickstart-answers.json
config/integrations.json

# Build artifacts
dist/
build/
*.egg-info/
__pycache__/
**/__pycache__/
*.pyc

# Local dev
.venv/
venv/
.idea/
.vscode/
.DS_Store

